# =============================================================================
# Sub2API Production Environment Template
# =============================================================================
# Copy to .env on the Linux VPS and replace all CHANGE_ME values.
# Never commit the generated .env file.
# =============================================================================

SUB2API_IMAGE=weishaw/sub2api:latest
BIND_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_FRONTEND_URL=https://api.example.com
SERVER_TRUSTED_PROXIES=127.0.0.1/32,::1/128
RUN_MODE=standard
TZ=Asia/Shanghai

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
POSTGRES_DB=sub2api
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10

REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10

ADMIN_EMAIL=admin@example.com
# Leave empty to auto-generate on first boot, then read it once from logs.
ADMIN_PASSWORD=

JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Production default: require HTTPS upstream URLs and disallow private hosts.
SECURITY_URL_ALLOWLIST_ENABLED=true
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=api.anthropic.com,api.openai.com

# Optional: outbound proxy for GitHub update checks and pricing data.
UPDATE_PROXY_URL=

# Optional: Gemini OAuth, not required for the first Claude/Codex launch.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
